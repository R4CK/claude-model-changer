# Force LF line endings for all text files in the repository.
# This guarantees that source files have identical bytes on every OS,
# which is critical for: (a) the bundle reproducibility CI check, and
# (b) cross-platform hook script execution.
#
# Windows-only scripts keep CRLF because cmd.exe / older PowerShell
# parsers can be picky.

# Default: text files use LF
*               text=auto eol=lf

# Source files: always LF
*.js            text eol=lf
*.json          text eol=lf
*.md            text eol=lf
*.sh            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.txt           text eol=lf
*.html          text eol=lf
*.css           text eol=lf
LICENSE         text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf

# Windows-only scripts: keep CRLF
*.bat           text eol=crlf
*.ps1           text eol=crlf

# Defensive: mark known binary types so Git doesn't try to diff them
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.zip           binary
*.rar           binary
