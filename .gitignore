# Runtime logs (generated during usage)
logs/*.jsonl
logs/*.json
logs/*.html
logs/*.log
logs/*.flag
logs/*.md
!logs/.gitkeep

# Runtime caches
**/.preflight-cache.json
**/.write-probe

# LLM-fallback learn suggestions (per-user usage data)
logs/learn-suggestions.jsonl
logs/learned-keywords.json

# Hook error log (per-user, captures hook exceptions)
logs/hook-errors.jsonl

# Dependencies
node_modules/

# VS Code extension build output
vscode-extension/out/
vscode-extension/node_modules/

# User-specific settings
.claude/settings.local.json
.claude/worktrees/

# Local archives & legacy installer
*.rar
*.zi
*.zip
claude-modell-changer-install.js

# Auto-synced external skills (managed by scripts/sync-external-skills.js
# and scripts/sync-karpathy-skills.js). Only `skills/model-router/` ships
# with the repo; everything else is pulled at runtime per repo prefix.
skills/acs-*/
skills/ecc-*/
skills/od-*/
skills/nlb-*/
skills/karpathy-*/
logs/external-skills-last-sync.json
logs/karpathy-last-sync.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
