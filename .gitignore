# Runtime logs (generated during usage)
logs/*.jsonl
logs/*.json
logs/*.html
logs/*.log
logs/*.flag
logs/*.md
logs/.last-rotation
!logs/.gitkeep

# Runtime caches
**/.preflight-cache.json
**/.write-probe

# LLM-fallback learn suggestions (per-user usage data)
logs/learn-suggestions.jsonl
logs/learned-keywords.json

# Hook error log (per-user, captures hook exceptions)
logs/hook-errors.jsonl

# Dependencies
node_modules/

# VS Code extension build output
vscode-extension/out/
vscode-extension/node_modules/

# User-specific settings
.claude/settings.local.json
.claude/worktrees/

# Local archives & legacy installer
*.rar
*.zi
*.zip
claude-modell-changer-install.js

# Auto-synced external skills/agents/commands (managed by
# scripts/sync-external-skills.js and scripts/sync-karpathy-skills.js).
# v3.9.0: items keep their ORIGINAL repo names (no prefixes), so we can't
# pattern-match them. Instead we ignore EVERYTHING under skills/agents/commands
# and the only built-ins (model-router, the three worker agents, the plugin's
# own commands) stay tracked — git never ignores already-tracked files, so this
# only hides the runtime-synced (untracked) items. New synced items are ignored
# automatically; provenance is in logs/external-skills-manifest.json.
skills/*/
!skills/model-router/
agents/*.md
!agents/haiku-worker.md
!agents/opus-worker.md
!agents/sonnet-worker.md
commands/*.md
logs/external-skills-manifest.json
logs/external-skills-last-sync.json
logs/karpathy-last-sync.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
logs/external-skills-dedup.json
