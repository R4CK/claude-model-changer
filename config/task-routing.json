  "effort": {
    "enabled": true,
    "emitInOutput": true,
    "emitInSubagentHint": true,
    "emitThinkingBudget": true,
    "defaultLevel": "medium",
    "thinkingBudgets": {
      "low": 0,
      "medium": 5000,
      "high": 16000
    },
    "rules": {
      "highCategories": [
        "architecture",
        "security",
        "planning",
        "system_design",
        "performance_audit",
        "large_refactoring",
        "multi_file_work",
        "algorithms",
        "tech_debt"
      ],
      "lowCategories": [
        "typo_fix",
        "formatting",
        "rename",
        "comments",
        "status",
        "imports",
        "search_list"
      ],
      "lowConfidenceThreshold": 40,
      "multiFileThreshold": 4,
      "structuralHighThreshold": 6,
      "lowEffortConfidenceThreshold": 70
    },
    "_comment": "Effort = reasoning/thinking budget (Low/Medium/High) the model should use. Orthogonal to model selection. The plugin SUGGESTS effort in the hook output; the user/Claude decides whether to follow it via the UI Effort control (Ctrl+E in Claude Code). Per-category override: add 'defaultEffort' field to any models.<model>.categories.<key> object."
  },
  "goalVerification": {
    "enabled": true,
    "minRatingsPerPair": 5,
    "poorThreshold": 2.5,
    "autoApply": false
  },
  "learn": {
    "autoApply": {
      "enabled": false,
      "minOccurrences": 5,
      "_comment": "When LLM-fallback suggests the same keyword N+ times (default 5), auto-add it to logs/learned-keywords.json (per-user, gitignored). The runtime config loader deep-merges learned-keywords.json into task-routing.json so the keyword takes effect immediately. To share keywords across machines/teams, run /learn-promote and add the diff to task-routing.json via PR."
    }
  },
  "preflight": {
    "enabled": true,
    "opusMinWords": 20,
    "suggestFileRefs": true,
    "suggestCriteria": true
  },
  "anomalyDetection": {
    "enabled": true,
    "thresholds": {
      "opusSpike": 2,
      "costSpike": 2,
      "scoreDrift": 3
    }
  },
  "apiLimits": {
    "enabled": false,
    "requestsPerMinute": 60,
    "tokensPerMinute": 100000,
    "warnAtPercent": 80,
    "forceHaikuAtPercent": 95
  },
  "planLimits": {
