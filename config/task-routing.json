  "scoring": {
    "weights": {
      "keyword": 0.35,
      "multiFile": 0.2,
      "structure": 0.2,
      "wordCount": 0.15,
      "codeBlocks": 0.1
    },
    "keywordInfluence": "override",
    "questionReduction": 0.8,
    "multiFileIndicators": [
      "multiple files",
      "several files",
      "all files",
      "across files",
      "many files",
      "each file",
      "every file",
      "throughout",
      "project-wide",
      "codebase-wide",
      "repo-wide",
      "components",
      "modules",
      "services",
      "layers",
      "frontend and backend",
      "client and server",
      "database and api",
      "api and ui"
    ]
  },
  "overrideMarkers": [
    "@haiku",
    "@sonnet",
    "@opus"
  ],
  "autoMode": {
    "enabled": true,
    "autoThresholds": {
      "haiku": [
        1,
        2
      ],
      "opus": [
        8,
        10
      ]
    },
    "llmFallback": {
      "enabled": false,
      "_comment": "Opt-in LLM fallback. When the deterministic scorer's confidence is < 40 OR no keyword matches, the hook outputs a hint instructing Claude to classify the prompt with the haiku-worker subagent (already shipped with this plugin). No API key required - uses the existing Claude Code session. Set enabled: true to activate."
    },
    "borderlineZones": [
      3,
      4,
      7,
      8
    ],
    "borderlineAutoResolve": {
      "enabled": true,
      "minHistory": 5,
      "minAvgRating": 3.5
    }
  },
  "costEstimates": {
    "haiku": {
      "inputPer1M": 1,
      "outputPer1M": 5,
      "label": "fast & affordable"
    },
    "sonnet": {
      "inputPer1M": 3,
      "outputPer1M": 15,
      "label": "balanced cost/performance"
    },
    "opus": {
      "inputPer1M": 15,
      "outputPer1M": 75,
      "label": "most capable, highest cost"
    }
  },
  "modelIds": {
    "haiku": "claude-haiku-4-5",
    "sonnet": "claude-sonnet-4-6",
    "opus": "claude-opus-4-7",
    "opus-1m": "claude-opus-4-7[1m]"
  },
  "contextWindows": {
    "haiku": 200000,
    "sonnet": 200000,
    "opus": 200000,
    "opus-1m": 1000000
  },
  "fastMode": {
    "enabled": true,
    "detectFromUserSettings": true
  },
  "karpathySync": {
    "enabled": true,
    "intervalHours": 24,
    "background": true
  },
  "memoryIntegration": {
    "enabled": true,
    "influenceEffort": true
  },
  "mcpToolAwareness": {
    "enabled": true,
    "tools": [
      "playwright",
      "browser_",
      "puppeteer",
      "github",
      "gh ",
      "git pr",
      "pull request",
      "slack",
      "send message",
      "gmail",
      "email",
      "vercel",
      "netlify",
      "deploy",
      "firefox",
      "fox_",
      "chrome",
      "context7",
      "fetch docs",
      "memory",
      "memorize",
      "scheduled task",
      "cron"
    ]
  },
  "skillIntegration": {
    "enabled": true,
    "overrideRouting": true,
    "rules": [
      { "match": "superpowers:debugging", "model": "sonnet", "effort": "high", "reason": "debugging requires deliberation" },
      { "match": "superpowers:systematic-debugging", "model": "sonnet", "effort": "high", "reason": "systematic debugging requires deliberation" },
      { "match": "superpowers:test-driven-development", "model": "sonnet", "effort": "medium", "reason": "TDD is moderate complexity" },
      { "match": "superpowers:writing-plans", "model": "opus", "effort": "high", "reason": "planning is opus territory" },
      { "match": "superpowers:brainstorming", "model": "opus", "effort": "high", "reason": "brainstorming benefits from opus reasoning" },
      { "match": "frontend-design", "model": "sonnet", "effort": "medium", "reason": "frontend design is moderate" },
      { "match": "feature-dev:code-architect", "model": "opus", "effort": "high", "reason": "architecture design is opus" },
      { "match": "code-review:code-review", "model": "sonnet", "effort": "medium", "reason": "code review is moderate" },
      { "match": "anthropic-skills:web-artifacts-builder", "model": "sonnet", "effort": "medium", "reason": "elaborate UI artifact" },
      { "match": "anthropic-skills:skill-creator", "model": "opus", "effort": "high", "reason": "skill creation needs careful design" }
    ]
  },
  "planMode": {
    "enabled": true,
    "scoreBoost": 1,
    "detectFromKeywords": true,
    "keywords": [
      "tervezd meg",
      "készíts tervet",
      "design plan",
      "make a plan",
      "create a plan",
      "plan the implementation",
      "tervezzük meg",
      "step-by-step plan",
      "architecture plan",
      "implementation plan"
    ]
  },
  "logging": {
    "enabled": true
  },
  "contextAware": {
    "enabled": true,
    "projectSignals": {
      "python": {
        "boostKeywords": ["django", "flask", "fastapi", "pandas", "numpy"],
        "defaultBoost": 0
      },
      "javascript": {
        "boostKeywords": ["react", "express", "node", "npm"],
        "defaultBoost": 0
      },
      "typescript": {
        "boostKeywords": ["typescript", "angular", "nest"],
        "defaultBoost": 0
      },
      "rust": {
        "boostKeywords": ["rust", "cargo", "crate"],
        "defaultBoost": 1
      },
      "go": {
        "boostKeywords": ["goroutine", "channel", "go mod"],
        "defaultBoost": 0
      }
    }
  },
  "sessionStickiness": {
    "enabled": true,
    "topicChangeThreshold": 0.3
  },
  "savingsTracking": {
    "enabled": true,
    "avgTokensPerTask": {
      "haiku": 1500,
      "sonnet": 3000,
      "opus": 6000
    }
  },
  "budgets": {
    "enabled": false,
    "period": "daily",
    "limits": {
      "haiku": 500000,
      "sonnet": 200000,
      "opus": 50000
    },
    "warnAt": 80,
    "blockAutoRouteAt": 100
  },
  "rateLimit": {
    "maxAutoRoutesPerMinute": 5,
    "cooldownSeconds": 60
  },
  "safeMode": false,
  "promptHints": {
    "enabled": true,
    "hints": {
      "haiku": "Tip: Keep it short and specific - one clear task per prompt works best with fast models.",
      "sonnet": "Tip: Include relevant context but stay focused - describe what and why for best results.",
      "opus": "Tip: Include full context, architecture details, constraints, and expected behavior for best results."
    }
  },
  "contextMonitor": {
    "enabled": true,
    "maxContextTokens": 200000,
    "thresholds": {
      "compactSuggest": 55,
      "compactWarn": 65,
      "compactForce": 75,
      "forceCheaper": 90
    },
    "taskSplitThreshold": 40,
    "taskSplitMinScore": 6
  },
  "adaptiveWeights": {
    "enabled": true,
    "minRatings": 10,
    "minWeight": 0.05,
    "maxWeight": 0.6
  },
