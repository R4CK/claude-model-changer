{
  "$schema": "./external-skills.schema.json",
  "version": "3.0",
  "description": "Auto-synced external skill/agent/command sources. Items keep their ORIGINAL names from the source repos — no prefixes are added. When the same name appears in more than one repo, the first repo (in this list's order) wins and later duplicates are skipped, so there is exactly one item per name. Provenance is tracked in logs/external-skills-manifest.json (used by prune + /skills-status) instead of name prefixes.",
  "sync": {
    "enabled": true,
    "intervalHours": 24,
    "background": true
  },
  "repos": [
    {
      "name": "open-design",
      "url": "https://github.com/nexu-io/open-design",
      "enabled": true,
      "sources": [
        {
          "kind": "skill",
          "layout": "subfolder",
          "skillsPath": "skills",
          "excludeFolders": []
        }
      ]
    },
    {
      "name": "ui-ux-pro-max-skill",
      "url": "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill",
      "enabled": true,
      "sources": [
        {
          "kind": "skill",
          "layout": "root-single",
          "destFolderName": "ui-ux-pro-max"
        }
      ]
    },
    {
      "name": "awesome-claude-skills",
      "url": "https://github.com/ComposioHQ/awesome-claude-skills",
      "enabled": true,
      "sources": [
        {
          "kind": "skill",
          "layout": "root-multi",
          "excludeFolders": ["composio-skills", "connect-apps-plugin", "document-skills"]
        }
      ]
    },
    {
      "name": "everything-claude-code",
      "url": "https://github.com/affaan-m/everything-claude-code",
      "enabled": true,
      "sources": [
        {
          "kind": "skill",
          "layout": "subfolder",
          "skillsPath": "skills"
        },
        {
          "kind": "agent",
          "layout": "flat-md",
          "skillsPath": "agents"
        },
        {
          "kind": "command",
          "layout": "flat-md",
          "skillsPath": "commands"
        }
      ]
    },
    {
      "name": "superpowers",
      "url": "https://github.com/obra/superpowers.git",
      "enabled": true,
      "sources": [
        {
          "kind": "skill",
          "layout": "subfolder",
          "skillsPath": "skills"
        }
      ]
    },
    {
      "name": "ruflo",
      "url": "https://github.com/ruvnet/ruflo.git",
      "enabled": true,
      "sources": [
        {
          "kind": "skill",
          "layout": "subfolder",
          "skillsPath": ".agents/skills"
        },
        {
          "kind": "skill",
          "layout": "subfolder",
          "skillsPath": ".claude/skills"
        },
        {
          "kind": "agent",
          "layout": "nested-md",
          "skillsPath": ".claude/agents",
          "excludeFolders": []
        },
        {
          "kind": "command",
          "layout": "nested-md",
          "skillsPath": ".claude/commands",
          "excludeFolders": []
        },
        {
          "kind": "skill",
          "layout": "plugin-multi",
          "skillsPath": "plugins",
          "innerPath": "skills",
          "innerLayout": "subfolder"
        },
        {
          "kind": "agent",
          "layout": "plugin-multi",
          "skillsPath": "plugins",
          "innerPath": "agents",
          "innerLayout": "flat-md"
        },
        {
          "kind": "command",
          "layout": "plugin-multi",
          "skillsPath": "plugins",
          "innerPath": "commands",
          "innerLayout": "flat-md"
        }
      ]
    },
    {
      "name": "obsidian-cli-skill",
      "url": "https://github.com/pablo-mano/Obsidian-CLI-skill.git",
      "enabled": true,
      "sources": [
        {
          "kind": "skill",
          "layout": "subfolder",
          "skillsPath": "skills"
        }
      ]
    }
  ]
}
