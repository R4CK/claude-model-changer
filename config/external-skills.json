{
  "$schema": "./external-skills.schema.json",
  "version": "1.0",
  "description": "Auto-synced skill sources. sync-external-skills.js clones each repo on first run, then on subsequent runs only fetches/copies when the remote HEAD has changed. Skill folders are mirrored into the plugin's skills/ dir, optionally prefixed to avoid name collisions.",
  "sync": {
    "enabled": true,
    "intervalHours": 24,
    "background": true
  },
  "repos": [
    {
      "name": "open-design",
      "url": "https://github.com/nexu-io/open-design",
      "layout": "subfolder",
      "skillsPath": "skills",
      "destPrefix": "od-",
      "enabled": true,
      "excludeFolders": []
    },
    {
      "name": "ui-ux-pro-max-skill",
      "url": "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill",
      "layout": "root-single",
      "destFolderName": "nlb-ui-ux-pro-max",
      "enabled": true
    },
    {
      "name": "awesome-claude-skills",
      "url": "https://github.com/ComposioHQ/awesome-claude-skills",
      "layout": "root-multi",
      "destPrefix": "acs-",
      "enabled": true,
      "excludeFolders": ["composio-skills", "connect-apps-plugin", "document-skills"]
    },
    {
      "name": "everything-claude-code",
      "url": "https://github.com/affaan-m/everything-claude-code",
      "layout": "subfolder",
      "skillsPath": "skills",
      "destPrefix": "ecc-",
      "enabled": true,
      "excludeFolders": []
    }
  ]
}
